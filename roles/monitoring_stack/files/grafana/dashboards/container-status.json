      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "clamp_max(time() - container_last_seen{job=\"cadvisor\", instance=\"ryzen\", name!=\"\", image!=\"\"} < 120, 1) or clamp_max(container_last_seen{job=\"cadvisor\", instance=\"ryzen\", name!=\"\", image!=\"\"} * 0, 0)",
          "instant": true,
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "title": "Ryzen containers",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 101,
      "title": "Uptime history",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 3,
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "left",
        "rowHeight": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "clamp_max(time() - container_last_seen{job=\"cadvisor\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\"} < 120, 1)",
          "legendFormat": "{{ name }} ({{ instance }})",
          "range": true,
          "refId": "A",
          "instant": false
        }
      ],
      "title": "Container uptime timeline",
      "type": "state-timeline"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Restarts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 4,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "manual",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "topk(15, changes(container_start_time_seconds{job=\"cadvisor\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\"}[$__range]) > 0)",
          "instant": true,
          "legendFormat": "{{ name }} ({{ instance }})",
          "refId": "A"
        }
      ],
      "title": "Container restarts in selected range",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 5,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "manual",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "topk(10, increase(container_oom_events_total{job=\"cadvisor\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\"}[$__range]) > 0)",
          "instant": true,
          "legendFormat": "{{ name }} ({{ instance }})",
          "refId": "A"
        }
      ],
      "title": "OOM kills in selected range",
      "type": "bargauge"
    }
