global:
  resolve_timeout: 5m

route:
  receiver: "ntfy"
  group_by: ["alertname", "instance"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    # Suppress Prometheus self-test watchdog alert
    - receiver: "null"
      matchers:
        - alertname = "Watchdog"

receivers:
  - name: "null"

  - name: "ntfy"
    webhook_configs:
      - url: "http://{{ nas_ip }}:{{ ntfy_service_port }}/homelab-alerts"
        send_resolved: true

templates: []
