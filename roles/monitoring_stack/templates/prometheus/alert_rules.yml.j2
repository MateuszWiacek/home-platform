{% set nas_host = groups['n100'][0] %}
{% set nas_apps_mountpoint = hostvars[nas_host].docker_root_dir %}
{% set nas_media_mountpoint = hostvars[nas_host].media_root_dir %}
{% set nas_smartctl_enabled = hostvars[nas_host].smartctl_exporter_enabled | default(false) | bool %}
groups:
  - name: host_health
    rules:
      - alert: HostDown
        expr: up{job="node_exporter"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Node {% raw %}{{ $labels.instance }}{% endraw %} is unreachable"
          description: "Node Exporter on {% raw %}{{ $labels.instance }}{% endraw %} has stopped responding."

      - alert: HighCPUUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 85
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "High CPU on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "CPU usage on {% raw %}{{ $labels.instance }}{% endraw %} has been above 85% for 10+ minutes."

      - alert: HighMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 90
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Memory usage on {% raw %}{{ $labels.instance }}{% endraw %} is above 90%."

      - alert: DiskSpaceLow
        expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 15
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Low disk space on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Root filesystem on {% raw %}{{ $labels.instance }}{% endraw %} has less than 15% free."

      - alert: DiskSpaceCritical
        expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 5
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Critical disk space on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Root filesystem on {% raw %}{{ $labels.instance }}{% endraw %} has less than 5% free."

      - alert: NasAppsPoolUsageHigh
        expr: 100 - ((node_filesystem_avail_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_apps_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"} / node_filesystem_size_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_apps_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"}) * 100) > {{ nas_apps_pool_warning_percent }}
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "NAS apps pool usage is high"
          description: "{{ nas_apps_mountpoint }} is above {{ nas_apps_pool_warning_percent }}% used."

      - alert: NasAppsPoolUsageCritical
        expr: 100 - ((node_filesystem_avail_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_apps_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"} / node_filesystem_size_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_apps_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"}) * 100) > {{ nas_apps_pool_critical_percent }}
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "NAS apps pool usage is critical"
          description: "{{ nas_apps_mountpoint }} is above {{ nas_apps_pool_critical_percent }}% used."

      - alert: NasMediaPoolUsageHigh
        expr: 100 - ((node_filesystem_avail_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_media_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"} / node_filesystem_size_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_media_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"}) * 100) > {{ nas_media_pool_warning_percent }}
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "NAS media pool usage is high"
          description: "{{ nas_media_mountpoint }} is above {{ nas_media_pool_warning_percent }}% used."

      - alert: NasMediaPoolUsageCritical
        expr: 100 - ((node_filesystem_avail_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_media_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"} / node_filesystem_size_bytes{job="node_exporter", instance="nas", mountpoint="{{ nas_media_mountpoint }}", fstype!~"tmpfs|overlay|squashfs"}) * 100) > {{ nas_media_pool_critical_percent }}
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "NAS media pool usage is critical"
          description: "{{ nas_media_mountpoint }} is above {{ nas_media_pool_critical_percent }}% used."

  - name: exporter_health
    rules:
      - alert: CadvisorDown
        expr: up{job="cadvisor"} == 0
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "cAdvisor unavailable on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Container metrics for {% raw %}{{ $labels.instance }}{% endraw %} are missing."

      - alert: ContainerOOMKilled
        expr: increase(container_oom_events_total{name!=""}[5m]) > 0
        labels:
          severity: critical
        annotations:
          summary: "OOM kill in container {% raw %}{{ $labels.name }}{% endraw %}"
          description: "Container {% raw %}{{ $labels.name }}{% endraw %} was OOM-killed. Check memory limits."

{% if nas_smartctl_enabled %}
  - name: nas_disk_health
    rules:
      - alert: SmartctlExporterDown
        expr: up{job="smartctl", instance="nas"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "SMART exporter is down on NAS"
          description: "Prometheus cannot scrape SMART data from the NAS."

      - alert: SmartDiskFailing
        expr: smartctl_device_smart_status{instance="nas"} == 0
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "SMART health failed on {% raw %}{{ $labels.device }}{% endraw %}"
          description: "SMART status reports failure for {% raw %}{{ $labels.device }}{% endraw %}."

      - alert: SmartDiskCriticalWarning
        expr: smartctl_device_critical_warning{instance="nas"} > 0
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "NVMe critical warning on {% raw %}{{ $labels.device }}{% endraw %}"
          description: "SMART critical warning is non-zero for {% raw %}{{ $labels.device }}{% endraw %}."

      - alert: SmartDiskTemperatureHigh
        expr: smartctl_device_temperature{instance="nas", temperature_type="current"} > {{ smartctl_temperature_warning_celsius }}
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Disk temperature is high on {% raw %}{{ $labels.device }}{% endraw %}"
          description: "{% raw %}{{ $labels.device }}{% endraw %} is above {{ smartctl_temperature_warning_celsius }} C."

      - alert: SmartDiskTemperatureCritical
        expr: smartctl_device_temperature{instance="nas", temperature_type="current"} > {{ smartctl_temperature_critical_celsius }}
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "Disk temperature is critical on {% raw %}{{ $labels.device }}{% endraw %}"
          description: "{% raw %}{{ $labels.device }}{% endraw %} is above {{ smartctl_temperature_critical_celsius }} C."

      - alert: SmartMediaErrorsIncreasing
        expr: increase(smartctl_device_media_errors{instance="nas"}[24h]) > 0 or increase(smartctl_device_num_err_log_entries{instance="nas"}[24h]) > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Disk error counters increased on {% raw %}{{ $labels.device }}{% endraw %}"
          description: "SMART media or error log counters increased for {% raw %}{{ $labels.device }}{% endraw %} during the last 24 hours."
{% endif %}
