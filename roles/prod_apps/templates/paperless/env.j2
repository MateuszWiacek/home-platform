# Database connection settings
PAPERLESS_REDIS=redis://paperless_redis:6379
PAPERLESS_DBHOST=paperless_db
PAPERLESS_DBPASS={{ vault_paperless_db_password }} # Stored in secrets.yml

# OCR and Regional settings
PAPERLESS_OCR_LANGUAGE=pol+eng+deu
PAPERLESS_TIME_ZONE={{ timezone }}

# Performance settings for Ryzen 6600H
# Enable derotate and clean for better OCR quality
PAPERLESS_OCR_USER_ARGS='{"derotate": true, "clean": true}'

# Security and access
# Required for reverse proxy - prevents CSRF Forbidden errors
PAPERLESS_URL=https://{{ paperless_domain }}
PAPERLESS_CSRF_TRUSTED_ORIGINS=https://{{ paperless_domain }}
PAPERLESS_ALLOWED_HOSTS={{ paperless_domain }}
PAPERLESS_FORCE_SCRIPT_NAME=

# Ensure UID/GID matches your TrueNAS 'apps_group' (1000)
USERMAP_UID={{ app_uid }}
USERMAP_GID={{ app_gid }}



# Additional languages to install (this triggers the download of tesseract-ocr-pol)
PAPERLESS_OCR_LANGUAGES=pol deu
{% if paperless_auth_mode == 'oidc' and vault_paperless_oauth_client_id is defined and vault_paperless_oauth_client_secret is defined and (vault_paperless_oauth_client_id | length) > 0 and (vault_paperless_oauth_client_secret | length) > 0 %}

# Optional OIDC — Authentik integration
# Redirect URI in Authentik must be: https://{{ paperless_domain }}/accounts/oidc/authentik/login/callback/
PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect
PAPERLESS_SOCIALACCOUNT_PROVIDERS={"openid_connect": {"APPS": [{"provider_id": "authentik", "name": "Authentik", "client_id": "{{ vault_paperless_oauth_client_id }}", "secret": "{{ vault_paperless_oauth_client_secret }}", "settings": {"server_url": "https://{{ authentik_domain }}/application/o/paperless/.well-known/openid-configuration"}}]}}
{% endif %}
