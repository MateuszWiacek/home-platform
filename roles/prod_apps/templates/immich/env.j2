# Core settings
IMMICH_VERSION={{ immich_version }}
NODE_ENV=production

# Database
DB_HOSTNAME=immich_postgres
DB_USERNAME=immich
DB_PASSWORD={{ vault_immich_db_password }}
DB_DATABASE_NAME=immich

# Redis
REDIS_HOSTNAME=immich_redis

# Timezone
TZ={{ timezone }}

# Upload location
UPLOAD_LOCATION={{ mnt_photos }}
{% if immich_auth_mode == 'oidc' and vault_immich_oauth_client_id is defined and vault_immich_oauth_client_secret is defined and (vault_immich_oauth_client_id | length) > 0 and (vault_immich_oauth_client_secret | length) > 0 %}

# Optional OIDC - Authentik integration
# Redirect URI in Authentik must be: https://{{ immich_domain }}/auth/login
IMMICH_OAUTH_ENABLED=true
IMMICH_OAUTH_ISSUER_URL=https://{{ authentik_domain }}/application/o/immich/
IMMICH_OAUTH_CLIENT_ID={{ vault_immich_oauth_client_id }}
IMMICH_OAUTH_CLIENT_SECRET={{ vault_immich_oauth_client_secret }}
IMMICH_OAUTH_SCOPE=openid email profile
IMMICH_OAUTH_AUTO_REGISTER=true
IMMICH_OAUTH_AUTO_LAUNCH=false
IMMICH_OAUTH_BUTTON_TEXT=Login with Authentik
{% endif %}
