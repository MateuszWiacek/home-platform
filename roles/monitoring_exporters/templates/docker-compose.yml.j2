services:
  node-exporter:
    container_name: node_exporter
    image: "prom/node-exporter:{{ node_exporter_version }}"
    command:
      - "--path.rootfs=/host"
      - "--path.procfs=/host/proc"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"
    volumes:
      - /:/host:ro,rslave
    ports:
      - "{{ node_exporter_port }}:9100"
    pid: host
    restart: always
    deploy:
      resources:
        limits:
          memory: {{ node_exporter_memory_limit }}

  cadvisor:
    container_name: cadvisor
    image: "gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}"
    command:
      - "--port=8080"
      - "--housekeeping_interval=30s"
      - "--docker_only=true"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "{{ cadvisor_port }}:8080"
    restart: always
    deploy:
      resources:
        limits:
          memory: {{ cadvisor_memory_limit }}

{% if smartctl_exporter_enabled | default(false) | bool %}
  smartctl-exporter:
    container_name: smartctl_exporter
    image: "prometheuscommunity/smartctl-exporter:{{ smartctl_exporter_version }}"
    command:
      - "--smartctl.interval={{ smartctl_exporter_poll_interval }}"
      - "--smartctl.rescan={{ smartctl_exporter_rescan_interval }}"
      - "--smartctl.device-exclude={{ smartctl_exporter_device_exclude_regex }}"
      - "--web.listen-address=:9633"
    user: "0:0"
    privileged: true
    volumes:
      - /run/udev:/run/udev:ro
    ports:
      - "{{ smartctl_exporter_port }}:9633"
    restart: always
    deploy:
      resources:
        limits:
          memory: {{ smartctl_exporter_memory_limit }}
{% endif %}

{% if authentik_postgres_exporter_enabled | default(false) | bool %}
  authentik-postgres-exporter:
    container_name: authentik_postgres_exporter
    image: "quay.io/prometheuscommunity/postgres-exporter:{{ authentik_postgres_exporter_version }}"
    environment:
      DATA_SOURCE_URI: "authentik-db:5432/authentik?sslmode=disable"
      DATA_SOURCE_USER: "authentik"
      DATA_SOURCE_PASS: "{{ authentik_postgres_password }}"
      PG_EXPORTER_EXTEND_QUERY_PATH: "/etc/postgres_exporter/authentik-queries.yml"
    volumes:
      - {{ exporters_stack_dir }}/authentik-queries.yml:/etc/postgres_exporter/authentik-queries.yml:ro
    networks:
      - proxy_net
    ports:
      - "{{ authentik_postgres_exporter_port }}:9187"
    restart: always
    deploy:
      resources:
        limits:
          memory: {{ authentik_postgres_exporter_memory_limit }}
{% endif %}

  promtail:
    container_name: promtail
    image: "grafana/promtail:{{ promtail_version }}"
    command: -config.file=/etc/promtail/promtail.yml
    volumes:
      - {{ exporters_stack_dir }}/promtail/promtail.yml:/etc/promtail/promtail.yml:ro
      - {{ exporters_stack_dir }}/promtail:/var/lib/promtail
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /etc/localtime:/etc/localtime:ro
    ports:
      - "127.0.0.1:{{ promtail_port }}:{{ promtail_port }}"
    restart: always
    deploy:
      resources:
        limits:
          memory: {{ promtail_memory_limit }}

{% if dozzle_agent_enabled | default(false) | bool %}
  dozzle-agent:
    container_name: dozzle_agent
    image: "ghcr.io/amir20/dozzle:{{ dozzle_agent_version }}"
    command: agent
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "{{ nas_ip }}:{{ dozzle_agent_port }}:7007"
    restart: always
    deploy:
      resources:
        limits:
          memory: {{ dozzle_agent_memory_limit }}
{% endif %}

{% if authentik_postgres_exporter_enabled | default(false) | bool %}
networks:
  proxy_net:
    external: true
{% endif %}
