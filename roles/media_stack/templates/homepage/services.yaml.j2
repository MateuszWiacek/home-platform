---
- Infrastructure:
    - Proxmox VE:
        icon: proxmox.png
        href: "https://{{ proxmox_domain }}"
        description: "Hypervisor & VM Management"
          
    - TrueNAS:
        icon: truenas.png
        href: "https://{{ truenas_domain }}"
        description: "Core Storage & Apps"
{% if truenas_api_key is defined and (truenas_api_key | length) > 0 %}
        widget:
          type: truenas
          url: "{{ truenas_internal_url }}"
          key: "{{ truenas_api_key }}"
          verify: false
{% endif %}
{% if syncthing_enabled | default(false) %}

    - Syncthing:
        icon: syncthing.png
        href: "https://{{ syncthing_domain }}"
        description: "File Synchronization"
{% endif %}

- Security & Identity:
    - Authentik:
        icon: authentik.png
        href: "https://{{ authentik_domain }}"
        description: "SSO & Identity Provider"

    - AdGuard Home:
        icon: adguard-home.png
        href: "https://{{ adguard_domain }}"
        description: "Network-wide DNS protection"

    - Vaultwarden:
        icon: vaultwarden.png
        href: "https://{{ vaultwarden_domain }}"
        description: "Password Vault"

    - Portainer:
        icon: portainer.png
        href: "https://{{ portainer_domain }}"
        description: "Container Management"
- Media & Docs:
    - Jellyfin:
        icon: jellyfin.png
        href: "https://{{ jellyfin_domain }}"
        description: "Media Server"
{% if jellyfin_api_key is defined and (jellyfin_api_key | length) > 0 %}
        widget:
          type: jellyfin
          url: "http://{{ nas_ip }}:{{ jellyfin_service_port }}"
          key: "{{ jellyfin_api_key }}"
          enableBlocks: true
{% endif %}

    - Navidrome:
        icon: navidrome.png
        href: "https://{{ navidrome_domain }}"
        description: "Music Streaming"
{% if audiobookshelf_enabled | default(false) %}

    - Audiobookshelf:
        icon: audiobookshelf.png
        href: "https://{{ audiobookshelf_domain }}"
        description: "Audiobooks & Podcasts"
{% endif %}
{% if calibre_web_enabled | default(false) %}

    - Calibre-Web:
        icon: calibre-web.png
        href: "https://{{ calibre_web_domain }}"
        description: "Ebook Library"
{% endif %}

    - SiYuan:
        icon: siyuan.png
        href: "https://{{ siyuan_domain }}"
        description: "Knowledge Base & Notes"

    - Excalidraw:
        icon: excalidraw.png
        href: "https://{{ excalidraw_domain }}"
        description: "Collaborative Whiteboard"

    - Mealie:
        icon: mealie.png
        href: "https://{{ mealie_domain }}"
        description: "Recipe Manager"

    - Linkwarden:
        icon: linkwarden.png
        href: "https://{{ linkwarden_domain }}"
        description: "Bookmark Archive"

    - Immich:
        icon: immich.png
        href: "https://{{ immich_domain }}"
        description: "Photo & Video Library"
{% if immich_api_key is defined and (immich_api_key | length) > 0 %}
        widget:
          type: immich
          url: "http://{{ ryzen_ip }}:{{ immich_service_port }}"
          key: "{{ immich_api_key }}"
{% endif %}

    - Paperless:
        icon: paperless-ngx.png
        href: "https://{{ paperless_domain }}"
        description: "Document Archive"
{% if paperless_api_key is defined and (paperless_api_key | length) > 0 %}
        widget:
          type: paperlessngx
          url: "http://{{ ryzen_ip }}:{{ paperless_service_port }}"
          key: "{{ paperless_api_key }}"
{% endif %}

- Routing & Edge:
    - Traefik:
        icon: traefik.png
        href: "{{ traefik_internal_url }}"
        description: "Edge Router & Reverse Proxy"
        widget:
          type: traefik
          url: "{{ traefik_internal_url }}"
{% if monitoring_enabled | default(false) | bool %}

    - Grafana:
        icon: grafana.png
        href: "https://{{ grafana_domain }}"
        description: "Metrics & Alerts Dashboard"
{% endif %}

- Utility Tools:
    - Stirling-PDF:
        icon: stirling-pdf.png
        href: "https://{{ stirling_pdf_domain }}"
        description: "PDF Toolbox"

    - IT-Tools:
        icon: it-tools.png
        href: "https://{{ it_tools_domain }}"
        description: "Developer & Admin Utilities"
