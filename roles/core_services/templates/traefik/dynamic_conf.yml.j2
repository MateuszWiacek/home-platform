  services:
    truenas:
      loadBalancer:
        servers:
          - url: "{{ truenas_internal_url }}"
        passHostHeader: true

    proxmox:
      loadBalancer:
        servers:
          - url: "{{ proxmox_internal_url }}"
        serversTransport: "insecureTransport"

{% if enable_remote_apps_routes %}
    paperless:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ paperless_service_port }}"
        passHostHeader: true

    immich:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ immich_service_port }}"
        passHostHeader: true

    stirling-pdf:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ stirling_pdf_service_port }}"
        passHostHeader: true

    it-tools:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ it_tools_service_port }}"
        passHostHeader: true

    navidrome:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ navidrome_service_port }}"
        passHostHeader: true
{% if audiobookshelf_enabled | default(false) %}

    audiobookshelf:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ audiobookshelf_service_port }}"
        passHostHeader: true
{% endif %}
{% if calibre_web_enabled | default(false) %}

    calibre-web:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ calibre_web_service_port }}"
        passHostHeader: true
{% endif %}

    siyuan:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ siyuan_service_port }}"
        passHostHeader: true

    excalidraw:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ excalidraw_service_port }}"
        passHostHeader: true

    mealie:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ mealie_service_port }}"
        passHostHeader: true

    linkwarden:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ linkwarden_service_port }}"
        passHostHeader: true
{% if monitoring_enabled | default(false) | bool %}

    grafana:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ grafana_service_port }}"
        passHostHeader: true
{% endif %}
{% if syncthing_enabled | default(false) %}

    syncthing:
      loadBalancer:
        servers:
          - url: "http://{{ ryzen_ip }}:{{ syncthing_service_port }}"
        passHostHeader: true
{% endif %}
{% endif %}

  serversTransports:
    insecureTransport:
      insecureSkipVerify: true

tcp:
  routers:
    ldap-secure:
      entryPoints:
        - "ldaps"
      rule: "HostSNI(`{{ authentik_domain }}`)"
      service: "ldap-outpost"
      tls:
        certResolver: "myresolver"

  services:
    ldap-outpost:
      loadBalancer:
        servers:
          - address: "authentik-ldap-outpost:3389"
