      entryPoints:
        - "websecure"
      tls:
        certResolver: "myresolver"
{% if it_tools_auth_mode == 'forwardauth' %}
      middlewares:
        - "authentik-auth"
{% endif %}

    navidrome:
      rule: "Host(`{{ navidrome_domain }}`)"
