      entryPoints:
        - "websecure"
      tls:
        certResolver: "myresolver"
{% if navidrome_auth_mode == 'forwardauth' %}
      middlewares:
        - "authentik-auth"
{% endif %}
{% if audiobookshelf_enabled | default(false) %}

    audiobookshelf:
