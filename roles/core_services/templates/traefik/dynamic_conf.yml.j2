      service: "audiobookshelf"
      entryPoints:
        - "websecure"
      tls:
        certResolver: "myresolver"
{% if audiobookshelf_auth_mode == 'forwardauth' %}
      middlewares:
        - "authentik-auth"
{% endif %}
{% endif %}
