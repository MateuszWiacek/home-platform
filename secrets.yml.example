---
# Copy this file to secrets.yml and encrypt it with:
# ansible-vault encrypt secrets.yml

# === Traefik / Cloudflare ===
cert_email: "admin@example.com"
cloudflare_token: "CF_DNS_API_TOKEN_HERE"

# === Authentik ===
authentik_postgres_password: "CHANGE_ME"
authentik_secret_key: "CHANGE_ME"
authentik_ldap_token: "CHANGE_ME"

# === Optional Homepage widgets ===
# Leave empty to disable these widgets.
truenas_api_key: "CHANGE_ME"
authentik_api_token: "CHANGE_ME"


# === Immich / Paperless ===
vault_immich_db_password: "CHANGE_ME"
vault_paperless_db_password: "CHANGE_ME"

# === OIDC — Immich (Authentik) ===
# Create OAuth2/OIDC provider in Authentik, then paste client ID and secret here.
# Redirect URI: https://immich.<domain>/auth/login
vault_immich_oauth_client_id: "CHANGE_ME"
vault_immich_oauth_client_secret: "CHANGE_ME"

# === OIDC — Paperless (Authentik) ===
# Create OAuth2/OIDC provider in Authentik, then paste client ID and secret here.
# Redirect URI: https://paperless.<domain>/accounts/oidc/authentik/login/callback/
vault_paperless_oauth_client_id: "CHANGE_ME"
vault_paperless_oauth_client_secret: "CHANGE_ME"

# === SiYuan ===
vault_siyuan_access_code: "CHANGE_ME"

# === Linkwarden ===
vault_linkwarden_db_password: "CHANGE_ME"
vault_linkwarden_nextauth_secret: "CHANGE_ME"

immich_api_key: "CHANGE_ME"
paperless_api_key: "CHANGE_ME"
jellyfin_api_key: "CHANGE_ME"
