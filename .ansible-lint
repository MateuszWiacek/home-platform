---
# Ansible-lint configuration for homelab CI

# Profiles: min, basic, moderate, safety, shared, production
# Start with basic — tighten later as codebase matures.
profile: basic

# Exclude paths that are not Ansible content
exclude_paths:
  - .github/
  - docs/

# Skip rules that conflict with homelab design decisions
skip_list:
  # We intentionally use shell for docker compose (handlers, start tasks)
  - command-instead-of-shell
  # Jinja2 in YAML values triggers false positives
  - yaml[truthy]
  # Some role names use underscores (core_services, media_stack) — that's fine
  - role-name
  # Role defaults intentionally expose operator-facing variable names shared
  # across roles. Prefixing every default with the role name adds noise without
  # improving how this repo is operated.
  - var-naming
  # site.yml is a thin import wrapper; naming imported playbooks there is not
  # meaningful and ansible-lint flags it anyway.
  - name[play]

# Treat warnings as non-fatal during initial adoption
warn_list:
  - no-changed-when
  - no-handler
